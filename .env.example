# Copy to .env and fill in. .env is gitignored.

# Anthropic API key for the decision agent.
ANTHROPIC_API_KEY=

# Robinhood trading MCP. The OAuth bearer token obtained after authenticating
# the MCP server (`/mcp` in an interactive claude session, or your own OAuth
# flow). Until this is set, the agent runs in dry-run with a mock broker.
ROBINHOOD_MCP_URL=https://agent.robinhood.com/mcp/trading
ROBINHOOD_MCP_TOKEN=

# Master safety switch. MUST be the literal string "true" to place real orders.
# Anything else (including unset) = dry-run: intended orders are logged, nothing
# is placed.
LIVE=false
